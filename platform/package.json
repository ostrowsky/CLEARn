{
  "name": "softskills-platform",
  "private": true,
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "dev:api": "node ./node_modules/tsx/dist/cli.mjs watch ./apps/api/src/index.ts",
    "dev:client": "pnpm --filter @softskills/client start",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  },
  "pnpm": {
    "overrides": {
      "@babel/plugin-transform-modules-systemjs": ">=7.29.4",
      "@xmldom/xmldom": ">=0.8.13",
      "fast-uri": ">=3.1.2",
      "fastify": ">=5.8.5",
      "postcss": ">=8.5.10",
      "tar": ">=7.5.11"
    }
  }
}
