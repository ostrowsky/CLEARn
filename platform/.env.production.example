APP_ENV=production
APP_PORT=4000
APP_BASE_URL=https://api.clearn.example

# Public frontend origins allowed to call the API with credentials.
CORS_ALLOWED_ORIGINS=https://clearn.example,https://www.clearn.example

# Required strong secret, at least 32 characters. Store in the hosting secret manager.
ADMIN_SESSION_SECRET=replace-with-hosting-secret-manager-value

# Persistent disk mounted by the API host. The API derives:
# - content.json
# - admin-auth.json
# - uploads/
APP_STORAGE_ROOT=/var/lib/clearn

# Redis is required for production answering/chat sessions.
REDIS_URL=rediss://default:replace-with-secret@your-redis-host:6379

# AI provider routing. Keep selfhosted/free providers for pre-revenue traffic.
LLM_TEXT_PROVIDER=selfhosted
LLM_STT_PROVIDER=selfhosted
LLM_TTS_PROVIDER=huggingface
SELF_HOSTED_BASE_URL=http://localhost:11434/v1
SELF_HOSTED_SPEECH_BASE_URL=http://localhost:8010/v1
HF_TOKEN=
OPENAI_API_KEY=

# Frontend build-time variable for Vercel.
# Must be the deployed Fastify API host, not the static Vercel frontend.
EXPO_PUBLIC_API_BASE_URL=https://api.clearn.example
# Set only for deliberately read-only static preview builds where admin/AI/STT/TTS are expected to be disabled.
ALLOW_STATIC_ONLY_PREVIEW=0

